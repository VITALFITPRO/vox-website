# ============================================================
# SUPABASE — Variables de entorno
# Copia este archivo como .env y rellena con tus valores reales
# ============================================================

# URL de tu proyecto Supabase (Dashboard → Settings → API)
VITE_SUPABASE_URL=https://xxxxx.supabase.co

# Anon Key (pública, segura para frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# ============================================================
# NOTA: La SERVICE_ROLE_KEY va SOLO en Supabase Edge Functions
# como secreto. NUNCA ponerla aquí ni en el frontend.
#
# SECRETOS PARA EDGE FUNCTIONS (configurar en Supabase Dashboard):
#   SUPABASE_URL
#   SUPABASE_SERVICE_ROLE_KEY
#   MERCADOPAGO_ACCESS_TOKEN
#   RESEND_API_KEY
#   SITE_URL=https://voxlang.dev
#   ADMIN_SECRET_KEY=<tu-clave-secreta-para-panel-admin>
# ============================================================
